# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ressurect
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=ressurect

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-token-key
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# Firebase (use service account JSON file)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# AWS (for temporary credentials, also include AWS_SESSION_TOKEN)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_SESSION_TOKEN=your-aws-session-token-if-using-temporary-credentials
AWS_S3_BUCKET_NAME=resurrect-ai-audio

# ElevenLabs (requires two agents: Companion and Persona)
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_COMPANION_AGENT_ID=your-companion-agent-id
ELEVENLABS_PERSONA_AGENT_ID=your-persona-agent-id
ELEVENLABS_COMPANION_VOICE_ID=Rachel
ELEVENLABS_WEBHOOK_SECRET=your-webhook-secret-for-verification

# W&B (optional)
WANDB_API_KEY=your-wandb-api-key
WANDB_PROJECT=ressurect-ai

# Mistral (optional)
MISTRAL_API_KEY=your-mistral-api-key

# Server
PORT=3000
NODE_ENV=development
